# Environment Configuration for Face Recognition Attendance System

# Database Configuration
DATABASE_URL=sqlite:///./database/attendance.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/attendance_db

# Camera Settings
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Face Detection Settings
FACE_DETECTION_MODEL=mtcnn
DETECTION_CONFIDENCE=0.9

# Face Recognition Settings
FACE_RECOGNITION_MODEL=Facenet512
RECOGNITION_THRESHOLD=0.6
DISTANCE_METRIC=cosine

# Per-Model Recognition Thresholds (Cosine Distance, lower = stricter)
ARCFACE_THRESHOLD=0.32
FACENET512_THRESHOLD=0.28
VGGFACE_THRESHOLD=0.30

# Ensemble & Confidence
ENSEMBLE_VOTING_THRESHOLD=0.60
RECOGNITION_CONFIDENCE_FLOOR=0.05
MIN_VECTOR_PASS_RATIO=0.25

# Pose Rejection — only active when landmarks available (RetinaFace)
MAX_POSE_ANGLE=35
DRAW_LANDMARKS=True

# Attendance Settings
MIN_IMAGES_PER_STUDENT=10
ATTENDANCE_COOLDOWN=3600
SAVE_UNKNOWN_FACES=True

# Attendance & Tracker Hardening
ATTENDANCE_MIN_CONSISTENCY=5
IDENTITY_STABILITY_THRESHOLD=3

# Logging
LOG_LEVEL=INFO

# Security (Generate strong secrets for production)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Stream (Dashboard) Quality Settings
# Used by the recognition engine when pushing frames to the dashboard stream.
# Higher values = better quality but more CPU/network usage.
STREAM_FPS=30
STREAM_JPEG_QUALITY=85
# Optional downscale for streaming only (leave empty for full size)
STREAM_WIDTH=
STREAM_HEIGHT=
